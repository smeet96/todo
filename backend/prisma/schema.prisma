datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
    id Int @unique @default(autoincrement())
    name String
    email String @unique 
    password String 
    todos Todo[]
}

model Todo {
    id Int @unique @default(autoincrement())
    title String
    description String
    done Boolean
    authorid Int
    author User? @relation(fields: [authorid] , references: [id])
}